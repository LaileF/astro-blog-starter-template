<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* BACKGROUND (FIXED — LIGHTER) */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;

  background:
    radial-gradient(circle at center, rgba(200,160,60,0.08), transparent 70%),
    linear-gradient(135deg, #152b3a 0%, #1c7c5a 100%);
}

/* CIRCUIT (VISIBLE BUT SOFT) */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;

  background: url('/circuit.png') center/1500px no-repeat;
  opacity: 0.25; /* 👈 stronger so you can SEE it */
  filter: hue-rotate(140deg) brightness(1.1);

  z-index: -1;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* HUB */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* CENTER ENERGY PULSE */
.hub-glow {
  animation: pulse 3s infinite ease-in-out;
}

@keyframes pulse {
  0% { opacity: 0.2; transform: scale(0.9); }
  50% { opacity: 0.45; transform: scale(1.15); }
  100% { opacity: 0.2; transform: scale(0.9); }
}

.hub-card {
  position: relative;
  background: white;
  padding: 40px;
  border-radius: 20px;
  width: 340px;
  text-align: center;
  box-shadow: 0 30px 70px rgba(0,0,0,0.3);
}

/* CARDS */
.card {
  position: absolute;
  width: 360px;
  padding: 26px;
  background: white;
  border-radius: 18px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  transition: all 0.25s ease;
}

.card:hover {
  transform: translateY(-8px);
}

/* PUSH OUTWARD (MORE SPACE) */
.top-left     { top: 12%; left: 12%; }
.top-right    { top: 12%; right: 12%; }
.bottom-left  { bottom: 12%; left: 12%; }
.bottom-right { bottom: 12%; right: 12%; }

/* LOGOS */
.card img {
  width: 64px;
  height: 64px;
  object-fit: contain;
  margin-bottom: 14px;
}

/* CENTER LOGO FIX */
.hub-card img {
  width: 72px;
  height: 72px;
}

/* TEXT */
h3 { margin: 6px 0; }
p  { font-size: 14px; color: #444; }

/* LINKS */
a {
  font-size: 14px;
  color: #2563eb;
  text-decoration: none;
}

/* MATCH SPENDSCORE TEXT COLOR */
.highlight {
  color: #2563eb;
  font-size: 12px;
}

/* ✨ SIGNAL LINES */
.line {
  position: absolute;
  height: 2px;
  background: linear-gradient(to right, transparent, #22c55e, transparent);
  opacity: 0.4;
  animation: flow 3s linear infinite;
}

@keyframes flow {
  0% { transform: scaleX(0.3); opacity: 0.1; }
  50% { transform: scaleX(1); opacity: 0.5; }
  100% { transform: scaleX(0.3); opacity: 0.1; }
}

/* POSITION LINES */
.line-1 { top: 40%; left: 30%; width: 200px; transform-origin: left; }
.line-2 { top: 40%; right: 30%; width: 200px; transform-origin: right; }
.line-3 { bottom: 40%; left: 30%; width: 200px; transform-origin: left; }
.line-4 { bottom: 40%; right: 30%; width: 200px; transform-origin: right; }

</style>

<div class="bg"></div>

<div id="scene">

  <!-- SIGNAL LINES -->
  <div class="line line-1"></div>
  <div class="line line-2"></div>
  <div class="line line-3"></div>
  <div class="line line-4"></div>

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-glow"></div>
    <div class="hub-card">
      <img src="/logo.png" />
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        Apps designed to cut through noise across money, business, news, and compliance—so you always know what matters and clarity on what to do next.
      </p>
    </div>
  </div>

  <!-- FOUNDERROUTES -->
  <div class="card top-left">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>
      Build Your Business with direction—Not guesswork, custom downloads and an assitant that grows with you. Know what to do now—and what not to do.
    </p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- SPENDSCORE -->
<div class="card top-right">
  <img src="/spendscore.png" />
  <h3>SpendScore</h3>
  <p>
    Understand your money in real time, track your score. Build better habits without complexity.
  </p>
  <p class="highlight">Launching April 1</p>
</div>

  <!-- SOURCEBRIEF -->
  <div class="card bottom-left">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>
      The news, distilled. What matters to you. What’s true. Nothing extra.
    </p>
    <a href="https://forms.gle/diLbSQKf6aKchR3w7" target="_blank">
      Join waitlist →
    </a>
  </div>

  <!-- COMPLIANCE -->
  <div class="card bottom-right">
    <img src="/compliance.png" style="transform: scale(2);" />
    <h3>ComplianceIQ</h3>
    <p>
      Stay ahead of compliance without drowning in updates or spreadsheets.
    </p>
    <p style="font-size:12px;">Coming soon</p>
  </div>

</div>