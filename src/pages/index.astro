<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
}

/* 🔵 BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;
  background: linear-gradient(135deg, #1e3a5f 0%, #3a6b8a 100%);
}

/* 🟢 CIRCUIT */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.35;
  filter: hue-rotate(120deg) brightness(1.2) saturate(2);
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* HUB */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 40px;
  border-radius: 18px;
  width: 360px;
  text-align: center;
  box-shadow: 0 30px 80px rgba(0,0,0,0.25);
  animation: float 4s ease-in-out infinite;
  cursor: pointer;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

/* CARDS */
.card {
  position: absolute;
  width: 380px;
  padding: 28px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
}

/* POSITIONS */
.top-left     { top: 10%; left: 8%; }
.top-right    { top: 10%; right: 8%; }
.bottom-left  { bottom: 10%; left: 8%; }
.bottom-right { bottom: 10%; right: 8%; }

/* LOGOS */
.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100px;
  margin-bottom: 12px;
}

.logo-wrap img {
  max-height: 100px;
  transition: 0.2s ease;
}

.card:hover .logo-wrap img {
  transform: scale(1.08);
}

/* TEXT */
h3 { margin: 6px 0; font-size: 18px; }
p { font-size: 14px; color: #444; }

/* MODAL */
.modal {
  position: fixed;
  width: 360px;
  background: white;
  padding: 24px;
  border-radius: 14px;
  box-shadow: 0 25px 70px rgba(0,0,0,0.35);
  display: none;
  z-index: 30;
  transition: all 0.2s ease;
}

.modal a {
  display: inline-block;
  margin-top: 10px;
  color: #2563eb;
}

.close {
  margin-top: 15px;
  font-size: 12px;
  cursor: pointer;
  color: #888;
}

/* 📱 MOBILE */
@media (max-width: 900px) {

  #scene {
    height: auto;
    padding: 20px;
  }

  .hub {
    position: relative;
    transform: none;
    top: auto;
    left: auto;
    margin-bottom: 20px;
  }

  .hub-card,
  .card {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto 20px auto;
  }

  .top-left,
  .top-right,
  .bottom-left,
  .bottom-right {
    all: unset;
  }

  .modal {
    left: 0 !important;
    top: 0 !important;
    width: 100%;
    height: 100%;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
}
</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card" onclick="openModal(event,'signal')">
      <div class="logo-wrap"><img src="/logo.png" /></div>
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:14px; font-weight:500;">
        A system of tools designed to cut through noise across money, business, news, and compliance.
      </p>
      <p style="font-size:12px; color:#666;">Click any product to explore →</p>
    </div>
  </div>

  <!-- CARDS -->
  <div class="card top-left" onclick="openModal(event,'founder')">
    <div class="logo-wrap"><img src="/founderroutes.png" /></div>
    <h3>FounderRoutes</h3>
    <p>Build your business with direction—not guesswork.</p>
  </div>

  <div class="card top-right" onclick="openModal(event,'spend')">
    <div class="logo-wrap"><img src="/spendscore.png" /></div>
    <h3>SpendScore</h3>
    <p>Understand your money in real time and build better habits.</p>
  </div>

  <div class="card bottom-left" onclick="openModal(event,'source')">
    <div class="logo-wrap"><img src="/sourcebrief.png" /></div>
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. Nothing extra.</p>
  </div>

  <div class="card bottom-right" onclick="openModal(event,'compliance')">
    <div class="logo-wrap"><img src="/compliance.png" /></div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without overwhelm.</p>
  </div>

</div>

<div id="modal" class="modal"></div>

<script>
window.openModal = function(e,type) {
  const modal = document.getElementById('modal');

  const data = {
    signal: {
      title: "SignalRoutes",
      text: "SignalRoutes is a connected system of focused tools designed to cut through noise across business, money, news, and compliance.",
      extra: "Each product solves a specific problem—together they create clarity across your entire decision system.",
      cta: "System overview"
    },
    founder: {
      title: "FounderRoutes",
      text: "A guided system that tells you exactly what to do next in your business—eliminating guesswork.",
      extra: "Best for: founders and operators who want clarity and direction.",
      link: "https://founder-routes-app-rep-production.up.railway.app/",
      cta: "Explore FounderRoutes →"
    },
    spend: {
      title: "SpendScore",
      text: "A real-time financial awareness tool that helps you understand and improve your money habits.",
      extra: "Track behavior and build better financial decisions.",
      link: "mailto:Spendscorehelp@gmail.com",
      cta: "Get early access →"
    },
    source: {
      title: "SourceBrief",
      text: "News distilled to what actually matters—filtered, summarized, and stripped of noise.",
      extra: "Stay informed without wasting time.",
      link: "https://forms.gle/diLbSQKf6aKchR3w7",
      cta: "Join waitlist →"
    },
    compliance: {
      title: "ComplianceIQ",
      text: "A simplified approach to compliance without spreadsheets or overwhelm.",
      extra: "Built for business owners who need clarity.",
      cta: "In development"
    }
  };

  const item = data[type];

  modal.innerHTML = `
    <h3>${item.title}</h3>
    <p>${item.text}</p>
    <p>${item.extra}</p>
    ${item.link ? `<a href="${item.link}" target="_blank">${item.cta}</a>` : `<p style="color:#2563eb;">${item.cta}</p>`}
    <div class="close" onclick="closeModal()">Close</div>
  `;

  modal.style.display = 'block';

  /* MOBILE */
  if (window.innerWidth < 900) {
    modal.style.left = "0px";
    modal.style.top = "0px";
    return;
  }

  const rect = e.currentTarget.getBoundingClientRect();

  if (rect.left > window.innerWidth / 2) {
    modal.style.left = (rect.left - 380 - 25) + "px";
  } else {
    modal.style.left = (rect.right + 25) + "px";
  }

  modal.style.top = rect.top + "px";
};

window.closeModal = function() {
  document.getElementById('modal').style.display = 'none';
};
</script>