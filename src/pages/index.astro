<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* 🔵 CLEAN BLUE BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;
  background: linear-gradient(135deg, #1e3a5f 0%, #3a6b8a 100%);
}

/* 🟢 GREEN CIRCUIT (FORCED CORRECT COLOR) */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.45;
  filter: hue-rotate(95deg) brightness(1.3) contrast(1.1);
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* ✅ CENTER HUB (FIXED PROPERLY) */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 36px;
  border-radius: 18px;
  width: 340px;
  text-align: center;
  box-shadow: 0 25px 70px rgba(0,0,0,0.25);
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-6px); }
  100% { transform: translateY(0px); }
}

/* CARDS */
.card {
  position: absolute;
  width: 360px;
  padding: 26px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
}

/* POSITIONS */
.top-left     { top: 10%; left: 10%; }
.top-right    { top: 10%; right: 10%; }
.bottom-left  { bottom: 10%; left: 10%; }
.bottom-right { bottom: 10%; right: 10%; }

/* LOGO FIX (CONSISTENT) */
.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 70px;
  margin-bottom: 10px;
}

.logo-wrap img {
  max-height: 70px;
  transform: scale(1.3);
}

/* TEXT */
h3 { margin: 6px 0; }
p { font-size: 14px; color: #444; }

/* MODAL */
.modal {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.modal-content {
  background: white;
  padding: 30px;
  border-radius: 16px;
  width: 420px;
  text-align: center;
}

.modal a {
  display: inline-block;
  margin-top: 10px;
  color: #2563eb;
}

.modal button {
  margin-top: 20px;
  padding: 8px 16px;
  border: none;
  background: #2563eb;
  color: white;
  border-radius: 6px;
}

</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card">
      <div class="logo-wrap">
        <img src="/logo.png" />
      </div>
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        Apps designed to cut through noise across money, business, news, and compliance—so you always know what matters and what to do next.
      </p>
    </div>
  </div>

  <!-- FOUNDERROUTES -->
  <div class="card top-left" onclick="openModal('founder')">
    <div class="logo-wrap"><img src="/founderroutes.png" /></div>
    <h3>FounderRoutes</h3>
    <p>Build your business with direction—not guesswork. Know what to do now—and what not to do.</p>
  </div>

  <!-- SPENDSCORE -->
  <div class="card top-right" onclick="openModal('spend')">
    <div class="logo-wrap"><img src="/spendscore.png" /></div>
    <h3>SpendScore</h3>
    <p>Understand your money in real time and track your score. Build better habits without complexity.</p>
  </div>

  <!-- SOURCEBRIEF -->
  <div class="card bottom-left" onclick="openModal('source')">
    <div class="logo-wrap"><img src="/sourcebrief.png" /></div>
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters to you. What’s true. Nothing extra.</p>
  </div>

  <!-- COMPLIANCE -->
  <div class="card bottom-right" onclick="openModal('compliance')">
    <div class="logo-wrap"><img src="/compliance.png" /></div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates or spreadsheets.</p>
  </div>

</div>

<!-- MODAL -->
<div class="modal" id="modal">
  <div class="modal-content" id="modal-content"></div>
</div>

<script>
function openModal(type) {
  const modal = document.getElementById('modal');
  const content = document.getElementById('modal-content');

  const data = {
    founder: {
      title: "FounderRoutes",
      text: "Business clarity system with tools and direction.",
      extra: "Email: FounderRoutes@gmail.com",
      link: "https://founder-routes-app-rep-production.up.railway.app/"
    },
    spend: {
      title: "SpendScore",
      text: "Track spending habits and improve your financial decisions.",
      extra: "Launching April • Email: Spendscorehelp@gmail.com"
    },
    source: {
      title: "SourceBrief",
      text: "Smart, distilled news that cuts through noise.",
      extra: "Join the waitlist",
      link: "https://forms.gle/diLbSQKf6aKchR3w7"
    },
    compliance: {
      title: "ComplianceIQ",
      text: "Simple compliance tracking and insights.",
      extra: "Currently in development"
    }
  };

  const item = data[type];

  content.innerHTML = `
    <h3>${item.title}</h3>
    <p>${item.text}</p>
    <p>${item.extra}</p>
    ${item.link ? `<a href="${item.link}" target="_blank">Open →</a>` : ""}
    <br/><br/>
    <button onclick="closeModal()">Close</button>
  `;

  modal.style.display = 'flex';
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
}
</script>