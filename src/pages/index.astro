---
---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body style="
  font-family: system-ui, sans-serif;
  margin:0;
  background:#f8f7f4;
  color:#1a1a1a;
">

<main style="
  position:relative;
  width:100%;
  height:90vh;
  max-width:1400px;
  margin:0 auto;
">

  <!-- CENTER HUB -->
  <div style="
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    text-align:center;
    z-index:2;
  ">

    <!-- glow -->
    <div style="
      position:absolute;
      width:260px;
      height:260px;
      top:50%;
      left:50%;
      transform:translate(-50%, -50%);
      background:radial-gradient(circle, rgba(34,197,94,0.2), transparent 70%);
      animation:pulse 3s infinite;
      z-index:0;
    "></div>

    <div style="
      position:relative;
      padding:24px 30px;
      border-radius:16px;
      background:white;
      border:1px solid #e5e5e5;
      box-shadow:0 20px 60px rgba(0,0,0,0.08);
      z-index:1;
    ">
      <img src="/logo.png" style="height:50px;" />
      <h2 style="margin:10px 0 5px;">SignalRoutes</h2>
      <p style="font-size:14px; color:#555;">
        Clear signals. Better decisions.
      </p>
    </div>

  </div>

  <!-- SVG CONNECTIONS -->
  <svg style="position:absolute; inset:0; z-index:1; pointer-events:none;">

    <!-- lines -->
    <line x1="50%" y1="50%" x2="15%" y2="20%" stroke="rgba(34,197,94,0.3)" stroke-width="2"/>
    <line x1="50%" y1="50%" x2="85%" y2="20%" stroke="rgba(34,197,94,0.3)" stroke-width="2"/>
    <line x1="50%" y1="50%" x2="15%" y2="80%" stroke="rgba(34,197,94,0.3)" stroke-width="2"/>
    <line x1="50%" y1="50%" x2="85%" y2="80%" stroke="rgba(34,197,94,0.3)" stroke-width="2"/>

    <!-- pulse dots -->
    <circle r="4" fill="#22c55e">
      <animateMotion dur="2s" repeatCount="indefinite"
        path="M 700 400 L 200 100" />
    </circle>

  </svg>

  <!-- CARDS -->

  <!-- top left -->
  <div class="card" style="top:10%; left:8%;">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity.</p>
    <a href="#">Visit →</a>
  </div>

  <!-- top right -->
  <div class="card" style="top:10%; right:8%;">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time.</p>
  </div>

  <!-- bottom left -->
  <div class="card" style="bottom:10%; left:8%;">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <!-- bottom right -->
  <div class="card" style="bottom:10%; right:8%;">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance.</p>
  </div>

</main>

<style>
.card {
  position:absolute;
  width:260px;
  padding:20px;
  border-radius:16px;
  background:white;
  border:1px solid #e5e5e5;
  box-shadow:0 10px 30px rgba(0,0,0,0.06);
  transition:all .25s ease;
}

.card img {
  width:42px;
  margin-bottom:10px;
}

.card:hover {
  transform:scale(1.04);
  box-shadow:0 20px 60px rgba(34,197,94,0.25);
}

.icon {
  width:42px;
  height:42px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#fafafa;
  border-radius:8px;
  margin-bottom:10px;
}

@keyframes pulse {
  0% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
  50% { opacity:0.9; transform:translate(-50%, -50%) scale(1.2); }
  100% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
}
</style>

</body>
</html>