<style>
/* BASE */
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
  background: #0f172a;
}

/* BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;

  background:
    radial-gradient(circle at center, rgba(200,160,60,0.18), transparent 55%),
    linear-gradient(135deg, #0f172a 0%, #0b3d2e 100%);
}

/* CIRCUIT OVERLAY */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;

  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.18;
  filter: hue-rotate(140deg) saturate(0.8);

  z-index: -1;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* CENTER HUB */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-glow {
  position: absolute;
  width: 420px;
  height: 420px;
  background: radial-gradient(circle, rgba(200,160,60,0.35), transparent);
  filter: blur(40px);
}

.hub-card {
  position: relative;
  background: white;
  padding: 28px;
  border-radius: 16px;
  width: 260px;
  text-align: center;
  box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  transform: scale(1.08);
}

/* CARDS */
.card {
  position: absolute;
  width: 260px;
  padding: 18px;
  background: white;
  border-radius: 14px;
  box-shadow: 0 12px 30px rgba(0,0,0,0.15);
}

/* CARD POSITIONS (tighter layout) */
.top-left     { top: 18%; left: 20%; }
.top-right    { top: 18%; right: 20%; }
.bottom-left  { bottom: 18%; left: 20%; }
.bottom-right { bottom: 18%; right: 20%; }

/* LOGOS */
.card img {
  width: 40px;
  margin-bottom: 10px;
}

/* TEXT */
h3 {
  margin: 6px 0;
}

p {
  font-size: 14px;
  color: #555;
}

/* LINKS */
a {
  font-size: 14px;
  color: #2563eb;
  text-decoration: none;
}
</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-glow"></div>
    <div class="hub-card">
      <img src="/logo.png" width="40" />
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        A system designed to cut through noise across money, business, news, and compliance.
      </p>
    </div>
  </div>

  <!-- TOP LEFT -->
  <div class="card top-left">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity.</p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- TOP RIGHT -->
  <div class="card top-right">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time.</p>
    <p style="font-size:12px;">Launching April 1</p>
  </div>

  <!-- BOTTOM LEFT -->
  <div class="card bottom-left">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters.</p>
    <a href="https://lailef.com/" target="_blank">
      Join waitlist →
    </a>
  </div>

  <!-- BOTTOM RIGHT -->
  <div class="card bottom-right">
    <img src="/logo.png" />
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without overwhelm.</p>
    <p style="font-size:12px;">Coming soon</p>
  </div>

</div>