---
---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body style="
  font-family: system-ui, sans-serif;
  margin:0;
  background:#f8f7f4;
  color:#1a1a1a;
">

<main style="
  position:relative;
  width:100%;
  height:100vh;
  max-width:1400px;
  margin:0 auto;
">

  <!-- CENTER HUB -->
  <div style="
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    text-align:center;
    z-index:3;
  ">

    <!-- GOLD/GREEN SIGNAL GLOW -->
    <div style="
      position:absolute;
      width:320px;
      height:320px;
      top:50%;
      left:50%;
      transform:translate(-50%, -50%);
      background:radial-gradient(circle, rgba(180,140,40,0.25), transparent 70%);
      animation:pulse 3s infinite;
      z-index:0;
    "></div>

    <div style="
      position:relative;
      padding:30px 40px;
      border-radius:18px;
      background:white;
      border:1px solid #e5e5e5;
      box-shadow:0 30px 80px rgba(0,0,0,0.12);
      z-index:1;
      width:300px;
    ">
      <img src="/logo.png" style="height:60px;" />
      <h2 style="margin:10px 0;">SignalRoutes</h2>
      <p style="color:#555;">Clear signals. Better decisions.</p>
    </div>

  </div>

  <!-- SVG CONNECTIONS (CLEAN, NO X) -->
  <svg style="position:absolute; inset:0; z-index:1;">

    <!-- lines from center -->
    <line x1="700" y1="400" x2="200" y2="120" stroke="rgba(180,140,40,0.4)" stroke-width="2"/>
    <line x1="700" y1="400" x2="1200" y2="120" stroke="rgba(180,140,40,0.4)" stroke-width="2"/>
    <line x1="700" y1="400" x2="200" y2="700" stroke="rgba(180,140,40,0.4)" stroke-width="2"/>
    <line x1="700" y1="400" x2="1200" y2="700" stroke="rgba(180,140,40,0.4)" stroke-width="2"/>

  </svg>

  <!-- CARDS (BIGGER + READABLE) -->

  <!-- TL -->
  <div class="card" style="top:8%; left:8%;">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="#">Visit →</a>
  </div>

  <!-- TR -->
  <div class="card" style="top:8%; right:8%;">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <p class="sub">Launching April 1</p>
  </div>

  <!-- BL -->
  <div class="card" style="bottom:8%; left:8%;">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true. Nothing extra.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <!-- BR -->
  <div class="card" style="bottom:8%; right:8%;">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <p class="sub">Coming soon</p>
  </div>

</main>

<style>
.card {
  position:absolute;
  width:320px;
  padding:26px;
  border-radius:18px;
  background:white;
  border:1px solid #e5e5e5;
  box-shadow:0 15px 40px rgba(0,0,0,0.08);
  transition:all .25s ease;
}

.card img {
  width:48px;
  margin-bottom:12px;
}

.card:hover {
  transform:scale(1.05);
  box-shadow:0 25px 80px rgba(180,140,40,0.35);
}

.sub {
  font-size:13px;
  color:#777;
}

.icon {
  width:48px;
  height:48px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#fafafa;
  border-radius:10px;
  margin-bottom:12px;
}

@keyframes pulse {
  0% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
  50% { opacity:1; transform:translate(-50%, -50%) scale(1.15); }
  100% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
}
</style>

</body>
</html>