<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* BACKGROUND (soft + not overpowering) */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;

  background: linear-gradient(135deg, #1b2d3a 0%, #1f6f54 100%);
}

/* CIRCUIT (simple + visible) */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.15;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* CENTER */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 36px;
  border-radius: 18px;
  width: 320px;
  text-align: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.25);
}

/* LIGHT PULSE (SAFE) */
.hub-card {
  animation: pulse 4s ease-in-out infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
  50% { box-shadow: 0 25px 80px rgba(34,197,94,0.25); }
  100% { box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
}

/* CARDS */
.card {
  position: absolute;
  width: 340px;
  padding: 24px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.25);
  transition: transform 0.2s ease;
}

.card:hover {
  transform: translateY(-6px);
}

/* POSITIONS */
.top-left     { top: 10%; left: 10%; }
.top-right    { top: 10%; right: 10%; }
.bottom-left  { bottom: 10%; left: 10%; }
.bottom-right { bottom: 10%; right: 10%; }

/* LOGOS (FIXED + CONSISTENT) */
.card img {
  width: 64px;
  height: 64px;
  object-fit: contain;
  margin-bottom: 12px;
}

.hub-card img {
  width: 72px;
  margin-bottom: 10px;
}

/* TEXT */
h3 { margin: 6px 0; }
p { font-size: 14px; color: #444; }

/* LINKS */
a {
  font-size: 14px;
  color: #2563eb;
  text-decoration: none;
}

/* SMALL HIGHLIGHT */
.highlight {
  color: #2563eb;
  font-size: 12px;
}

/* SIMPLE SIGNAL LINES (SAFE VERSION) */
.line {
  position: absolute;
  height: 2px;
  background: rgba(34,197,94,0.4);
}

.line-1 { top: 35%; left: 30%; width: 160px; }
.line-2 { top: 35%; right: 30%; width: 160px; }
.line-3 { bottom: 35%; left: 30%; width: 160px; }
.line-4 { bottom: 35%; right: 30%; width: 160px; }

</style>

<div class="bg"></div>

<div id="scene">

  <!-- LINES -->
  <div class="line line-1"></div>
  <div class="line line-2"></div>
  <div class="line line-3"></div>
  <div class="line line-4"></div>

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card">
      <img src="/logo.png" />
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        Apps designed to cut through noise across money, business, news, and compliance—so you always know what matters and what to do next.
      </p>
    </div>
  </div>

  <!-- FOUNDERROUTES -->
  <div class="card top-left">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>
      Build your business with direction—not guesswork. Know what to do now—and what not to do.
    </p>
    <a href="https://founder-routes-app-rep-production.up.railway.app/" target="_blank">
      Visit →
    </a>
  </div>

  <!-- SPENDSCORE -->
  <div class="card top-right">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>
      Understand your money in real time and track your score. Build better habits without complexity.
    </p>
    <p class="highlight">Launching April 1</p>
  </div>

  <!-- SOURCEBRIEF -->
  <div class="card bottom-left">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>
      The news, distilled. What matters to you. What’s true. Nothing extra.
    </p>
    <a href="https://forms.gle/diLbSQKf6aKchR3w7" target="_blank">
      Join waitlist →
    </a>
  </div>

  <!-- COMPLIANCE -->
  <div class="card bottom-right">
    <img src="/compliance.png" />
    <h3>ComplianceIQ</h3>
    <p>
      Stay ahead of compliance without drowning in updates or spreadsheets.
    </p>
    <p style="font-size:12px;">Coming soon</p>
  </div>

</div>