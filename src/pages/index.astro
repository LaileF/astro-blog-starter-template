---
// SignalRoutes — index.astro
// Drop this file into src/pages/index.astro in your GitHub repo
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SignalRoutes — Clear Signals. Better Decisions.</title>
<meta name="description" content="A suite of practical software tools helping founders, individuals, and organizations make clearer decisions — about money, business, news, and compliance.">
<meta property="og:title" content="SignalRoutes — Clear Signals. Better Decisions.">
<meta property="og:description" content="FounderRoutes · SpendScore · SourceBrief · ComplianceIQ — built by a founder, for founders.">
<meta property="og:url" content="https://signalroutes.work">
<meta property="og:image" content="/logo.png">
<link rel="icon" href="/logo.png">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ── RESET & TOKENS ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

:root {
  --ink: #0e0e0e;
  --paper: #f5f2eb;
  --warm: #e8e2d5;
  --signal: #c8441a;
  --muted: #7a7468;
  --border: #d4cfc5;
  --green: #2a6e4a;
  --amber: #b87414;
  --blue: #1a4a7a;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--paper);
  color: var(--ink);
  overflow-x: hidden;
}

/* ── SHARED IMAGE HELPERS ── */
.app-logo    { width: 56px; height: 56px; object-fit: contain; margin-bottom: 16px; display: block; border-radius: 10px; }
.app-logo-sm { width: 32px; height: 32px; object-fit: contain; border-radius: 6px; }
.nav-logo-img { height: 28px; object-fit: contain; vertical-align: middle; margin-right: 8px; }

/* ── NAV / HERO ── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr auto;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 70% 20%, rgba(200,68,26,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 80% at 10% 80%, rgba(42,110,74,0.06) 0%, transparent 50%);
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 60px 60px;
  opacity: 0.35;
  pointer-events: none;
}

nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 48px;
  position: relative;
  z-index: 10;
  border-bottom: 1px solid var(--border);
  background: rgba(245,242,235,0.85);
  backdrop-filter: blur(8px);
}
.nav-logo {
  font-family: 'DM Serif Display', serif;
  font-size: 1.4rem;
  color: var(--ink);
  letter-spacing: -0.02em;
}
.nav-logo span { color: var(--signal); }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--ink); }
.nav-cta {
  background: var(--ink) !important;
  color: var(--paper) !important;
  padding: 8px 20px;
  border-radius: 2px;
  transition: background 0.2s !important;
}
.nav-cta:hover { background: var(--signal) !important; }

.hero-body {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 48px 60px;
  position: relative;
  z-index: 5;
  max-width: 900px;
}
.hero-eyebrow {
  font-family: 'DM Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.6s 0.2s forwards;
}
.hero-headline {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(3.2rem, 7vw, 6.5rem);
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--ink);
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.7s 0.35s forwards;
}
.hero-headline em { font-style: italic; color: var(--signal); }
.hero-sub {
  font-size: 1.15rem;
  color: var(--muted);
  max-width: 560px;
  line-height: 1.65;
  font-weight: 300;
  margin-bottom: 44px;
  opacity: 0;
  animation: fadeUp 0.7s 0.5s forwards;
}
.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s 0.65s forwards;
}
.btn-primary {
  background: var(--signal);
  color: white;
  padding: 14px 32px;
  border-radius: 2px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  letter-spacing: 0.02em;
  transition: all 0.2s;
  border: 2px solid var(--signal);
}
.btn-primary:hover { background: transparent; color: var(--signal); }
.btn-secondary {
  background: transparent;
  color: var(--ink);
  padding: 14px 32px;
  border-radius: 2px;
  text-decoration: none;
  font-weight: 500;
  font-size: 0.9rem;
  letter-spacing: 0.02em;
  transition: all 0.2s;
  border: 2px solid var(--border);
}
.btn-secondary:hover { border-color: var(--ink); }

.hero-stats {
  display: flex;
  border-top: 1px solid var(--border);
  position: relative;
  z-index: 5;
  background: rgba(245,242,235,0.7);
  backdrop-filter: blur(4px);
  opacity: 0;
  animation: fadeUp 0.7s 0.8s forwards;
}
.stat-item { flex: 1; padding: 24px 48px; border-right: 1px solid var(--border); }
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'DM Serif Display', serif;
  font-size: 2rem;
  color: var(--ink);
  display: block;
  letter-spacing: -0.03em;
}
.stat-label {
  font-size: 0.78rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
}

/* ── SECTIONS ── */
section { padding: 100px 48px; }
.section-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--signal);
  margin-bottom: 16px;
}
.section-title {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  letter-spacing: -0.03em;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 20px;
}

/* ── ABOUT ── */
.about {
  background: var(--ink);
  color: var(--paper);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.about .section-label { color: var(--signal); }
.about .section-title { color: var(--paper); }
.about-body { font-size: 1.05rem; line-height: 1.75; color: rgba(245,242,235,0.75); font-weight: 300; }
.about-body p + p { margin-top: 20px; }
.about-body strong { color: var(--paper); font-weight: 500; }
.about-right { display: flex; flex-direction: column; gap: 24px; }
.founder-card {
  border: 1px solid rgba(245,242,235,0.15);
  padding: 32px;
  border-radius: 2px;
  background: rgba(245,242,235,0.04);
}
.founder-name { font-family: 'DM Serif Display', serif; font-size: 1.4rem; color: var(--paper); margin-bottom: 4px; }
.founder-title { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; font-family: 'DM Mono', monospace; }
.founder-bio { font-size: 0.9rem; color: rgba(245,242,235,0.65); line-height: 1.6; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 16px; }
.tag { background: rgba(200,68,26,0.2); color: #e8856a; padding: 4px 12px; border-radius: 2px; font-size: 0.75rem; font-family: 'DM Mono', monospace; letter-spacing: 0.05em; }

/* ── APPS ── */
.apps-section { background: var(--paper); }
.apps-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  margin-top: 60px;
  border: 1px solid var(--border);
}
.app-card {
  background: var(--paper);
  padding: 48px;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  position: relative;
  overflow: hidden;
  transition: background 0.3s;
}
.app-card:hover { background: var(--warm); }
.app-card:nth-child(2n) { border-right: none; }
.app-card:nth-child(3), .app-card:nth-child(4) { border-bottom: none; }
.app-card.outlier {
  grid-column: span 2;
  border-bottom: none;
  border-right: none;
  background: var(--warm);
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 40px;
}
.app-num { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--muted); letter-spacing: 0.1em; margin-bottom: 20px; }
.app-name { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: var(--ink); letter-spacing: -0.02em; margin-bottom: 8px; }
.app-tagline { font-size: 0.9rem; color: var(--muted); margin-bottom: 20px; line-height: 1.5; }
.app-desc { font-size: 0.88rem; color: var(--ink); line-height: 1.65; margin-bottom: 24px; font-weight: 300; }
.app-meta { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.72rem;
  font-family: 'DM Mono', monospace;
  letter-spacing: 0.06em;
  padding: 4px 10px;
  border-radius: 2px;
  text-transform: uppercase;
}
.status-live   { background: #d4eade; color: var(--green); }
.status-beta   { background: #fef3d4; color: var(--amber); }
.status-pipeline { background: #dce8f5; color: var(--blue); }
.status-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.price-tag {
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  color: var(--muted);
  border: 1px solid var(--border);
  padding: 4px 10px;
  border-radius: 2px;
}
.app-link {
  font-size: 0.8rem;
  color: var(--signal);
  text-decoration: none;
  font-weight: 500;
  letter-spacing: 0.02em;
  border-bottom: 1px solid currentColor;
  padding-bottom: 1px;
  transition: opacity 0.2s;
}
.app-link:hover { opacity: 0.7; }
.outlier-badge { text-align: center; white-space: nowrap; }
.outlier-label { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 8px; }
.outlier-value { font-family: 'DM Serif Display', serif; font-size: 2.5rem; color: var(--signal); display: block; }

/* ── TRACTION ── */
.traction { background: var(--warm); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
.traction-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 60px; }
.traction-item { padding: 32px; background: var(--paper); border: 1px solid var(--border); border-radius: 2px; }
.traction-num { font-family: 'DM Serif Display', serif; font-size: 3rem; color: var(--signal); letter-spacing: -0.04em; line-height: 1; margin-bottom: 8px; }
.traction-label { font-size: 0.85rem; color: var(--ink); font-weight: 500; margin-bottom: 6px; }
.traction-note { font-size: 0.78rem; color: var(--muted); line-height: 1.5; }

/* ── ROADMAP ── */
.roadmap { background: var(--paper); }
.roadmap-timeline { margin-top: 60px; position: relative; }
.roadmap-timeline::before {
  content: '';
  position: absolute;
  left: 120px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: var(--border);
}
.roadmap-item { display: grid; grid-template-columns: 120px 1fr; position: relative; }
.roadmap-item + .roadmap-item { border-top: 1px solid var(--border); }
.roadmap-date {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: var(--muted);
  letter-spacing: 0.08em;
  padding: 28px 24px 28px 0;
  text-align: right;
  line-height: 1.4;
}
.roadmap-content { padding: 28px 0 28px 40px; position: relative; }
.roadmap-content::before {
  content: '';
  position: absolute;
  left: -4px;
  top: 36px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--border);
  border: 2px solid var(--paper);
}
.roadmap-item.active .roadmap-content::before { background: var(--signal); }
.roadmap-item.done   .roadmap-content::before { background: var(--green); }
.roadmap-title { font-weight: 600; font-size: 0.95rem; color: var(--ink); margin-bottom: 4px; }
.roadmap-detail { font-size: 0.83rem; color: var(--muted); line-height: 1.5; }
.roadmap-revenue { font-family: 'DM Mono', monospace; font-size: 0.78rem; color: var(--signal); margin-top: 4px; }

/* ── INVEST ── */
.invest { background: var(--ink); color: var(--paper); }
.invest .section-label { color: var(--signal); }
.invest .section-title { color: var(--paper); }
.invest-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 60px; align-items: start; }
.invest-left p { font-size: 1rem; color: rgba(245,242,235,0.7); line-height: 1.75; font-weight: 300; margin-bottom: 20px; }
.invest-left strong { color: var(--paper); font-weight: 500; }
.needs-list { list-style: none; margin-top: 32px; }
.needs-list li { display: flex; gap: 16px; padding: 20px 0; border-bottom: 1px solid rgba(245,242,235,0.1); }
.needs-list li:last-child { border-bottom: none; }
.need-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
.need-title { font-weight: 500; color: var(--paper); margin-bottom: 4px; font-size: 0.95rem; }
.need-desc { font-size: 0.83rem; color: rgba(245,242,235,0.55); line-height: 1.55; }
.contact-card { border: 1px solid rgba(245,242,235,0.15); padding: 40px; background: rgba(245,242,235,0.04); }
.contact-card h3 { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--paper); margin-bottom: 8px; }
.contact-card p { font-size: 0.88rem; color: rgba(245,242,235,0.55); margin-bottom: 32px; line-height: 1.6; }
.contact-options { display: flex; flex-direction: column; gap: 12px; }
.contact-btn {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  text-decoration: none;
  border: 1px solid rgba(245,242,235,0.15);
  border-radius: 2px;
  transition: all 0.2s;
  background: rgba(245,242,235,0.03);
}
.contact-btn:hover { background: rgba(200,68,26,0.15); border-color: var(--signal); }
.contact-btn-icon { font-size: 1.1rem; flex-shrink: 0; }
.contact-btn-text strong { display: block; font-size: 0.88rem; color: var(--paper); font-weight: 500; }
.contact-btn-text span { font-size: 0.78rem; color: rgba(245,242,235,0.45); font-family: 'DM Mono', monospace; }
.contact-btn.highlight { background: rgba(200,68,26,0.08); border-color: var(--signal); }

/* ── FOOTER ── */
footer {
  padding: 40px 48px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--border);
}
.footer-logo { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--muted); }
.footer-logo span { color: var(--signal); }
.footer-note { font-size: 0.78rem; color: var(--muted); font-family: 'DM Mono', monospace; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
.reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s, transform 0.6s; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  nav { padding: 20px 24px; }
  .nav-links { display: none; }
  section { padding: 60px 24px; }
  .hero-body { padding: 60px 24px 40px; }
  .hero-stats { flex-wrap: wrap; }
  .stat-item { padding: 20px 24px; flex: 1 1 50%; }
  .about { grid-template-columns: 1fr; gap: 40px; }
  .apps-grid { grid-template-columns: 1fr; }
  .app-card:nth-child(2n) { border-right: 1px solid var(--border); }
  .app-card:nth-child(3) { border-bottom: 1px solid var(--border); }
  .app-card.outlier { grid-column: span 1; grid-template-columns: 1fr; }
  .traction-grid { grid-template-columns: 1fr; gap: 16px; }
  .invest-grid { grid-template-columns: 1fr; gap: 40px; }
  .roadmap-timeline::before { left: 80px; }
  .roadmap-item { grid-template-columns: 80px 1fr; }
  footer { flex-direction: column; gap: 12px; text-align: center; }
}
</style>
</head>
<body>

<!-- ── NAV / HERO ── -->
<section class="hero">
  <nav>
    <div class="nav-logo">
      <img src="/logo.png" alt="SignalRoutes" class="nav-logo-img">Signal<span>Routes</span>
    </div>
    <ul class="nav-links">
      <li><a href="#apps">Products</a></li>
      <li><a href="#traction">Traction</a></li>
      <li><a href="#roadmap">Roadmap</a></li>
      <li><a href="#invest" class="nav-cta">Connect</a></li>
    </ul>
  </nav>

  <div class="hero-body">
    <div class="hero-eyebrow">SignalRoutes · Ellensburg, WA · Est. 2025</div>
    <h1 class="hero-headline">Tools that cut<br>through the <em>noise.</em></h1>
    <p class="hero-sub">A suite of practical software products helping founders, individuals, and organizations make clearer decisions — about money, business, news, and compliance.</p>
    <div class="hero-actions">
      <a href="#apps" class="btn-primary">Explore Products</a>
      <a href="#invest" class="btn-secondary">Talk to Us</a>
    </div>
  </div>

  <div class="hero-stats">
    <div class="stat-item">
      <span class="stat-num">4</span>
      <span class="stat-label">Products in portfolio</span>
    </div>
    <div class="stat-item">
      <span class="stat-num">3</span>
      <span class="stat-label">States launched · WA · CA · NY</span>
    </div>
    <div class="stat-item">
      <span class="stat-num">10+</span>
      <span class="stat-label">Beta testers active</span>
    </div>
    <div class="stat-item">
      <span class="stat-num">Apr '26</span>
      <span class="stat-label">SpendScore Play Store launch</span>
    </div>
  </div>
</section>

<!-- ── ABOUT ── -->
<section class="about" id="about">
  <div>
    <div class="section-label reveal">The Story</div>
    <h2 class="section-title reveal">Built by a founder,<br>for founders.</h2>
    <div class="about-body reveal">
      <p>SignalRoutes was born out of a simple frustration: <strong>too much noise, not enough signal.</strong> Starting and running a business in Washington meant navigating a maze of regulations, financial tools, and information sources — none of them designed to work together.</p>
      <p>So we built the tools we wished existed. Each product in the SignalRoutes portfolio solves a real, specific problem — and together they form a system for <strong>clearer thinking and better decisions</strong> across every stage of business and personal growth.</p>
      <p>Bootstrapped, profitable-path focused, and building in public from Ellensburg, WA.</p>
    </div>
  </div>
  <div class="about-right reveal">
    <div class="founder-card">
      <div class="founder-name">Laile Fletcher</div>
      <div class="founder-title">Founder · Developer · Operator</div>
      <div class="founder-bio">Solo founder building a portfolio of practical SaaS tools from Ellensburg, WA. Background spanning fintech compliance, small business operations, and software development. Every product is built, tested, and shipped by someone who uses it.</div>
      <div class="tag-row">
        <span class="tag">Bootstrapped</span>
        <span class="tag">Ellensburg WA</span>
        <span class="tag">SaaS</span>
        <span class="tag">Solo Founder</span>
      </div>
    </div>
  </div>
</section>

<!-- ── PRODUCTS ── -->
<section class="apps-section" id="apps">
  <div class="section-label reveal">The Portfolio</div>
  <h2 class="section-title reveal">Four products.<br>One clear mission.</h2>

  <div class="apps-grid reveal">

    <!-- FounderRoutes -->
    <div class="app-card">
      <div class="app-num">01</div>
      <img src="/founderroutes.png" alt="FounderRoutes" class="app-logo">
      <div class="app-name">FounderRoutes</div>
      <div class="app-tagline">Build your business with direction — not guesswork.</div>
      <div class="app-desc">A 12-module guided curriculum for new and early-stage founders navigating the real complexity of starting a business — licensing, compliance, structure, and operations — built specifically for WA, CA, and NY. Think of it as having a knowledgeable advisor in your pocket, available 24/7.</div>
      <div class="app-meta">
        <span class="status-badge status-beta"><span class="status-dot"></span>Beta · 3 States</span>
        <span class="price-tag">$39.99 / mo Core · $79.99 / mo Pro</span>
      </div>
      <br>
      <a href="https://founder-routes-app-rep-production.up.railway.app" target="_blank" class="app-link">Request Beta Access →</a>
    </div>

    <!-- SpendScore -->
    <div class="app-card">
      <div class="app-num">02</div>
      <img src="/spendscore.png" alt="SpendScore" class="app-logo">
      <div class="app-name">SpendScore</div>
      <div class="app-tagline">Understand your money in real time.</div>
      <div class="app-desc">A mobile-first personal finance app that scores your spending behavior and builds better financial habits over time. Designed for people who want insight, not just tracking. Launching on Google Play mid-April 2026 — available in the US, EU, and Canada. Monetized via subscription and AdMob ad revenue.</div>
      <div class="app-meta">
        <span class="status-badge status-live"><span class="status-dot"></span>Launching Apr 2026</span>
        <span class="price-tag">$4.99 / mo · + AdMob</span>
