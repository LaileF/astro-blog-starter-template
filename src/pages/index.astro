---

<html lang="en">
  <head>
    <title>SignalRoutes</title>
  </head>

  <body style="
    font-family: system-ui, sans-serif;
    margin:0;
    background:#f8f7f4;
    color:#1a1a1a;
  ">

    <!-- MAIN WRAP -->
    <main style="
      max-width:1300px;
      margin:40px auto;
      padding:20px;
    ">

      <!-- HERO (THIS FIXES EMPTY FEEL) -->
      <div style="
        text-align:center;
        margin-bottom:60px;
      ">
        <img src="/logo.png" style="height:80px;" />

        <h1 style="
          margin:10px 0;
          font-size:40px;
          letter-spacing:-1px;
        ">
          SignalRoutes
        </h1>

        <p style="
          font-size:18px;
          font-weight:500;
          margin:0;
        ">
          Clear signals. Better decisions.
        </p>

        <p style="
          max-width:720px;
          margin:12px auto 0;
          color:#555;
          line-height:1.6;
        ">
          A system of tools designed to cut through noise across money, business, news, and compliance.
        </p>
      </div>

      <!-- CONNECTOR LINE (subtle system feel) -->
      <div style="
        height:1px;
        background:linear-gradient(to right, transparent, #ddd, transparent);
        margin:40px 0 60px;
      "></div>

      <!-- GRID -->
      <div style="
        display:grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap:28px;
      ">

        <!-- FounderRoutes -->
        <div style="
          padding:24px;
          border-radius:16px;
          background:white;
          border:1px solid #e5e5e5;
          transition:all .2s ease;
        ">
          <img src="/founderroutes.png" style="width:52px;" />
          <h3>FounderRoutes</h3>
          <p>
            Build your business with clarity. Know what to do now—and what not to do.
          </p>
          <a href="#" target="_blank">Visit →</a>
        </div>

        <!-- SpendScore -->
        <div style="
          padding:24px;
          border-radius:16px;
          background:white;
          border:1px solid #e5e5e5;
        ">
          <img src="/spendscore.png" style="width:52px;" />
          <h3>SpendScore</h3>
          <p>
            Understand your money in real time. Build better habits without complexity.
          </p>
          <p style="font-size:13px; color:#666;">
            Launching April 1 on Google Play
          </p>
        </div>

        <!-- SourceBrief -->
        <div style="
          padding:24px;
          border-radius:16px;
          background:white;
          border:1px solid #e5e5e5;
        ">
          <img src="/sourcebrief.png" style="width:52px;" />
          <h3>SourceBrief</h3>
          <p>
            The news, distilled. What matters. What’s true. Nothing extra.
          </p>

          <a href="https://forms.gle/ZmfuxiLXw5wnSC257" target="_blank" style="
            display:inline-block;
            margin-top:10px;
            font-size:13px;
            text-decoration:none;
            border-bottom:1px solid #999;
          ">
            Join waitlist →
          </a>
        </div>

        <!-- ComplianceIQ (FIXED FALLBACK) -->
        <div style="
          padding:24px;
          border-radius:16px;
          background:white;
          border:1px solid #e5e5e5;
        ">
          <div style="
            width:52px;
            height:52px;
            display:flex;
            align-items:center;
            justify-content:center;
            background:#fafafa;
            border-radius:8px;
            font-size:20px;
          ">
            ⚖️
          </div>

          <h3>ComplianceIQ</h3>
          <p>
            Stay ahead of compliance without drowning in updates.
          </p>
          <p style="font-size:13px; color:#777;">
            Coming soon
          </p>
        </div>

      </div>

      <!-- FOOT -->
      <p style="
        text-align:center;
        margin-top:60px;
        color:#666;
      ">
        Clarity first. Direction next.
      </p>

    </main>
  </body>
</html>