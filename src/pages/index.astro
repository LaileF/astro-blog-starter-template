---
---

<html lang="en">
<head>
  <title>SignalRoutes</title>
</head>

<body style="
  font-family: system-ui, sans-serif;
  margin:0;
  background:#f4f2ee;
  color:#1a1a1a;
">

<!-- TRUE CIRCUIT BACKGROUND -->
<div style="
  position:fixed;
  inset:0;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(180,140,40,0.05) 0px,
      rgba(180,140,40,0.05) 1px,
      transparent 1px,
      transparent 120px
    ),
    repeating-linear-gradient(
      90deg,
      rgba(180,140,40,0.05) 0px,
      rgba(180,140,40,0.05) 1px,
      transparent 1px,
      transparent 120px
    );
  z-index:0;
"></div>

<main style="
  position:relative;
  height:100vh;
  max-width:1400px;
  margin:0 auto;
  z-index:1;
">

  <!-- CENTER HUB -->
  <div style="
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    width:380px;
    text-align:center;
    z-index:3;
  ">

    <div style="
      position:absolute;
      width:420px;
      height:420px;
      top:50%;
      left:50%;
      transform:translate(-50%, -50%);
      background:radial-gradient(circle, rgba(180,140,40,0.3), transparent 70%);
      animation:pulse 3s infinite;
    "></div>

    <div style="
      position:relative;
      padding:34px;
      border-radius:20px;
      background:white;
      border:1px solid #e5e5e5;
      box-shadow:0 30px 80px rgba(0,0,0,0.12);
    ">
      <img src="/logo.png" style="height:70px;" />

      <h1>SignalRoutes</h1>

      <p style="font-weight:600;">Clear signals. Better decisions.</p>

      <p style="font-size:14px; color:#555;">
        A system of tools designed to cut through noise across money,
        business, news, and compliance—giving you clarity on what matters
        and what to do next.
      </p>
    </div>

  </div>

  <!-- CONNECTION SYSTEM -->
  <svg style="position:absolute; inset:0; z-index:2;">

    <!-- lines -->
    <line x1="700" y1="400" x2="200" y2="120" stroke="rgba(180,140,40,0.3)" stroke-width="2"/>
    <line x1="700" y1="400" x2="1200" y2="120" stroke="rgba(180,140,40,0.3)" stroke-width="2"/>
    <line x1="700" y1="400" x2="200" y2="700" stroke="rgba(180,140,40,0.3)" stroke-width="2"/>
    <line x1="700" y1="400" x2="1200" y2="700" stroke="rgba(180,140,40,0.3)" stroke-width="2"/>

    <!-- moving signals -->
    <circle r="4" fill="#b48c28">
      <animateMotion dur="2s" repeatCount="indefinite"
        path="M 700 400 L 200 120" />
    </circle>

    <circle r="4" fill="#b48c28">
      <animateMotion dur="2s" repeatCount="indefinite"
        path="M 700 400 L 1200 120" />
    </circle>

    <circle r="4" fill="#b48c28">
      <animateMotion dur="2s" repeatCount="indefinite"
        path="M 700 400 L 200 700" />
    </circle>

    <circle r="4" fill="#b48c28">
      <animateMotion dur="2s" repeatCount="indefinite"
        path="M 700 400 L 1200 700" />
    </circle>

  </svg>

  <!-- CARDS -->

  <div class="card" style="top:6%; left:6%;">
    <img src="/founderroutes.png" />
    <h3>FounderRoutes</h3>
    <p>Build your business with clarity. Know what to do now—and what not to do.</p>
    <a href="#">Visit →</a>
  </div>

  <div class="card" style="top:6%; right:6%;">
    <img src="/spendscore.png" />
    <h3>SpendScore</h3>
    <p>Understand your money in real time. Build better habits without complexity.</p>
    <p class="sub">Launching April 1</p>
  </div>

  <div class="card" style="bottom:6%; left:6%;">
    <img src="/sourcebrief.png" />
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. What’s true. Nothing extra.</p>
    <a href="https://forms.gle/ZmfuxiLXw5wnSC257">Join waitlist →</a>
  </div>

  <div class="card" style="bottom:6%; right:6%;">
    <div class="icon">⚖️</div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without drowning in updates.</p>
    <p class="sub">Coming soon</p>
  </div>

</main>

<style>
.card {
  position:absolute;
  width:360px;
  padding:28px;
  border-radius:20px;
  background:white;
  border:1px solid #e5e5e5;
  box-shadow:0 15px 50px rgba(0,0,0,0.08);
  transition:all .25s ease;
}

.card img {
  width:52px;
  margin-bottom:14px;
}

.card:hover {
  transform:scale(1.05);
  box-shadow:0 30px 100px rgba(180,140,40,0.4);
}

.sub {
  font-size:13px;
  color:#777;
}

.icon {
  width:52px;
  height:52px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#fafafa;
  border-radius:10px;
  margin-bottom:14px;
}

@keyframes pulse {
  0% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
  50% { opacity:1; transform:translate(-50%, -50%) scale(1.2); }
  100% { opacity:0.4; transform:translate(-50%, -50%) scale(1); }
}
</style>

</body>
</html>