<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
}

/* BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;
  background: linear-gradient(135deg, #1e3a5f 0%, #3a6b8a 100%);
}

/* CIRCUIT (USE YOUR GREEN PNG — NO FILTERS) */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.25;
    filter: #008C4A;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* CENTER */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 40px;
  border-radius: 18px;
  width: 360px;
  text-align: center;
  box-shadow: 0 30px 80px rgba(0,0,0,0.25);
  cursor: pointer;
}

/* CARDS */
.card {
  position: absolute;
  width: 380px;
  padding: 28px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: 0.2s ease;
}

.card:hover {
  transform: translateY(-6px);
}

/* POSITIONS */
.top-left     { top: 10%; left: 8%; }
.top-right    { top: 10%; right: 8%; }
.bottom-left  { bottom: 10%; left: 8%; }
.bottom-right { bottom: 10%; right: 8%; }

/* LOGOS */
.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100px;
  margin-bottom: 12px;
}

.logo-wrap img {
  max-height: 100px;
}

/* TEXT */
h3 { margin: 6px 0; }
p { font-size: 14px; color: #444; }

/* MODAL */
.modal {
  position: fixed;
  width: 360px;
  background: white;
  padding: 24px;
  border-radius: 14px;
  box-shadow: 0 25px 70px rgba(0,0,0,0.35);
  display: none;
  z-index: 30;
}

.modal a {
  display: inline-block;
  margin-top: 12px;
  padding: 10px 16px;
  background: #2563eb;
  color: white;
  border-radius: 6px;
  text-decoration: none;
}

.close {
  margin-top: 12px;
  font-size: 12px;
  cursor: pointer;
  color: #888;
}

/* MOBILE */
@media (max-width: 900px) {

  #scene {
    height: auto;
    padding: 20px;
  }

  .hub {
    position: relative;
    transform: none;
    margin-bottom: 20px;
  }

  .hub-card,
  .card {
    position: relative;
    width: 100%;
    max-width: 500px;
    margin: 0 auto 20px auto;
  }

  .top-left,
  .top-right,
  .bottom-left,
  .bottom-right {
    all: unset;
  }

  .modal {
    left: 0 !important;
    top: 0 !important;
    width: 100%;
    height: 100%;
    border-radius: 0;
  }
}
</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card" onclick="openModal(event,'signal')">
      <div class="logo-wrap"><img src="/logo.png" /></div>
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        A system of tools designed to cut through noise across money, business, news, and compliance.
      </p>
    </div>
  </div>

  <!-- CARDS -->
  <div class="card top-left" onclick="openModal(event,'founder')">
    <div class="logo-wrap"><img src="/founderroutes.png" /></div>
    <h3>FounderRoutes</h3>
    <p>Build your business with direction—not guesswork.</p>
  </div>

  <div class="card top-right" onclick="openModal(event,'spend')">
    <div class="logo-wrap"><img src="/spendscore.png" /></div>
    <h3>SpendScore</h3>
    <p>Understand your money in real time and build better habits.</p>
  </div>

  <div class="card bottom-left" onclick="openModal(event,'source')">
    <div class="logo-wrap"><img src="/sourcebrief.png" /></div>
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. Nothing extra.</p>
  </div>

  <div class="card bottom-right" onclick="openModal(event,'compliance')">
    <div class="logo-wrap"><img src="/compliance.png" /></div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without overwhelm.</p>
  </div>

</div>

<div id="modal" class="modal"></div>

<script>
window.closeModal = function() {
  document.getElementById('modal').style.display = 'none';
}

window.openModal = function(e,type) {
  const modal = document.getElementById('modal');
  const formLink = "https://forms.gle/QB4RgS2FrzicuuJf7";

  const data = {
    signal: {
      title: "SignalRoutes",
      text: "SignalRoutes is a suite of clarity tools for people and businesses drowning in noise. We help you understand your money with SpendScore, stay informed without doom scrolling with SourceBrief, get business direction with 
FounderRoutes, and stay compliant without overwhelmed with ComplianceIQ."

One brand. Four tools. Total clarity.",
      extra: "Explore the ecosystem or connect to learn more.",
      cta: "Connect / Learn More"
    },
    founder: {
      title: "FounderRoutes",
      text: "Get clear direction on what to do next in your business—without guesswork.",
      extra: "Built for founders and operators who want clarity.",
      cta: "Get access",
      link: "https://founder-routes-app-rep-production.up.railway.app/"
    },
    spend: {
      title: "SpendScore",
      text: "Understand your money, track your habits, and improve decisions.",
      extra: "Launching soon — early access available.",
      cta: "Join early access"
    },
    source: {
      title: "SourceBrief",
      text: "The news that actually matters — in under 5 minutes.",
      extra: "Published daily, emailed to you. Built for clarity without noise.",
      cta: "Subscribe",
      link: "https://sourcebrief.org"
    },
    compliance: {
      title: "ComplianceIQ",
      text: "Simplified compliance without overwhelm.",
      extra: "Designed for business owners who need clarity.",
      cta: "Get updates"
    }
  };

  const item = data[type];

  modal.innerHTML = `
  <h3>${item.title}</h3>
  <p>${item.text}</p>
  <p>${item.extra}</p>

  ${item.link ? `
  <a href="${item.link}" target="_blank" style="margin-right:10px;">
    Visit →
  </a>
` : ``}

${type !== 'source' ? `
  <a href="${formLink}" target="_blank">
    ${item.cta} →
  </a>
` : `
  <a href="${item.link}" target="_blank">
    ${item.cta} →
  </a>
`}

  <div class="close" onclick="closeModal()">Close</div>
`;

  modal.style.display = 'block';

  if (window.innerWidth < 900) {
    modal.style.left = "0px";
    modal.style.top = "0px";
    return;
  }

  const rect = e.currentTarget.getBoundingClientRect();

  if (rect.left > window.innerWidth / 2) {
    modal.style.left = (rect.left - 380 - 25) + "px";
  } else {
    modal.style.left = (rect.right + 25) + "px";
  }

  modal.style.top = rect.top + "px";
};
</script>