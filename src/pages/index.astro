<script>
function switchTab(name) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  document.querySelector('[data-tab="' + name + '"]').classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  // re-trigger reveal on newly visible tab
  setTimeout(() => {
    document.querySelectorAll('#tab-' + name + ' .reveal:not(.visible)').forEach(el => revealObs.observe(el));
  }, 80);
}

// Nav tab clicks
document.querySelectorAll('.nav-tab').forEach(btn => btn.addEventListener('click', () => switchTab(btn.dataset.tab)));

// Any element with data-switchtab
document.addEventListener('click', e => {
  const el = e.target.closest('[data-switchtab]');
  if (el) { e.preventDefault(); switchTab(el.dataset.switchtab); }
});

// Let's Connect button — goes to opportunity tab then scrolls to invest
document.getElementById('connectCta').addEventListener('click', () => {
  switchTab('opportunity');
  setTimeout(() => document.getElementById('invest').scrollIntoView({ behavior: 'smooth' }), 420);
});

// Scroll reveal
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

// Stagger grids
document.querySelectorAll('.traction-grid .traction-item, .apps-grid .app-card').forEach((el, i) => {
  el.style.transitionDelay = `${i * 0.08}s`;
});

// Progress bar
const prog = document.getElementById('scrollProgress');
window.addEventListener('scroll', () => {
  const h = document.documentElement.scrollHeight - window.innerHeight;
  prog.style.width = (h > 0 ? (window.scrollY / h) * 100 : 0) + '%';
});
</script>
