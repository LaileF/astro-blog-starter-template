<style>
body {
  margin: 0;
  font-family: system-ui, sans-serif;
  overflow: hidden;
}

/* 🔵 BACKGROUND */
.bg {
  position: fixed;
  inset: 0;
  z-index: -2;
  background: linear-gradient(135deg, #1e3a5f 0%, #3a6b8a 100%);
}

/* 🟢 CIRCUIT — BRIGHT + CLEAR */
.bg::after {
  content: "";
  position: absolute;
  inset: 0;
  background: url('/circuit.png') center/1400px no-repeat;
  opacity: 0.35;
  filter: brightness(1.5) saturate(1.5);
}

/* GREEN OVERLAY */
.bg::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(34, 197, 94, 0.35);
  mix-blend-mode: overlay;
}

/* SCENE */
#scene {
  position: relative;
  height: 100vh;
}

/* CENTER HUB */
.hub {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.hub-card {
  background: white;
  padding: 40px;
  border-radius: 18px;
  width: 360px;
  text-align: center;
  box-shadow: 0 30px 80px rgba(0,0,0,0.25);
  animation: float 4s ease-in-out infinite;
  cursor: pointer;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

/* CARDS */
.card {
  position: absolute;
  width: 380px;
  padding: 28px;
  background: white;
  border-radius: 16px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  cursor: pointer;
  transition: all 0.2s ease;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
}

/* POSITIONS */
.top-left     { top: 10%; left: 8%; }
.top-right    { top: 10%; right: 8%; }
.bottom-left  { bottom: 10%; left: 8%; }
.bottom-right { bottom: 10%; right: 8%; }

/* LOGOS BIGGER */
.logo-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80px;
  margin-bottom: 12px;
}

.logo-wrap img {
  max-height: 80px;
}

/* TEXT */
h3 { margin: 6px 0; font-size: 18px; }
p { font-size: 14px; color: #444; }

/* MODAL */
.modal {
  position: fixed;
  width: 360px;
  background: white;
  padding: 24px;
  border-radius: 14px;
  box-shadow: 0 25px 70px rgba(0,0,0,0.35);
  display: none;
  z-index: 30;
}

.modal a {
  display: inline-block;
  margin-top: 10px;
  color: #2563eb;
}

.close {
  margin-top: 15px;
  font-size: 12px;
  cursor: pointer;
  color: #888;
}
</style>

<div class="bg"></div>

<div id="scene">

  <!-- CENTER -->
  <div class="hub">
    <div class="hub-card" onclick="openModal(event,'signal')">
      <div class="logo-wrap"><img src="/logo.png" /></div>
      <h3>SignalRoutes</h3>
      <p>Clear signals. Better decisions.</p>
      <p style="font-size:13px;">
        A system of tools designed to cut through noise across money, business, news, and compliance.
      </p>
    </div>
  </div>

  <!-- CARDS -->
  <div class="card top-left" onclick="openModal(event,'founder')">
    <div class="logo-wrap"><img src="/founderroutes.png" /></div>
    <h3>FounderRoutes</h3>
    <p>Build your business with direction—not guesswork.</p>
  </div>

  <div class="card top-right" onclick="openModal(event,'spend')">
    <div class="logo-wrap"><img src="/spendscore.png" /></div>
    <h3>SpendScore</h3>
    <p>Understand your money in real time and build better habits.</p>
  </div>

  <div class="card bottom-left" onclick="openModal(event,'source')">
    <div class="logo-wrap"><img src="/sourcebrief.png" /></div>
    <h3>SourceBrief</h3>
    <p>The news, distilled. What matters. Nothing extra.</p>
  </div>

  <div class="card bottom-right" onclick="openModal(event,'compliance')">
    <div class="logo-wrap"><img src="/compliance.png" /></div>
    <h3>ComplianceIQ</h3>
    <p>Stay ahead of compliance without overwhelm.</p>
  </div>

</div>

<div id="modal" class="modal"></div>

<script>
window.openModal = function(e,type) {
  const modal = document.getElementById('modal');

  const data = {
    signal: {
      title: "SignalRoutes",
      text: "A central intelligence layer connecting all tools.",
      extra: "This is the system behind everything."
    },
    founder: {
      title: "FounderRoutes",
      text: "Business clarity system with tools + direction.",
      extra: "FounderRoutes@gmail.com",
      link: "https://founder-routes-app-rep-production.up.railway.app/"
    },
    spend: {
      title: "SpendScore",
      text: "Real-time financial awareness + behavior tracking.",
      extra: "Launching April • Spendscorehelp@gmail.com"
    },
    source: {
      title: "SourceBrief",
      text: "Distilled news built for clarity.",
      link: "https://forms.gle/diLbSQKf6aKchR3w7"
    },
    compliance: {
      title: "ComplianceIQ",
      text: "Compliance without spreadsheets or overwhelm.",
      extra: "In development"
    }
  };

  const item = data[type];

  modal.innerHTML = `
    <h3>${item.title}</h3>
    <p>${item.text}</p>
    ${item.extra ? `<p>${item.extra}</p>` : ""}
    ${item.link ? `<a href="${item.link}" target="_blank">Open →</a>` : ""}
    <div class="close" onclick="closeModal()">Close</div>
  `;

  modal.style.display = 'block';

  const rect = e.currentTarget.getBoundingClientRect();

  modal.style.top = rect.top + "px";
  modal.style.left = (rect.right + 15) + "px";
};

window.closeModal = function() {
  document.getElementById('modal').style.display = 'none';
};
</script>